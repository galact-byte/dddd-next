# dddd-next secrets template — copy to .env and fill in real values.
# .env is gitignored; this .env.example is committed as documentation.
#
# All keys are OPTIONAL: dddd scans fine without them. Only search-query
# targets (e.g. -t 'app="seeyon"') hit the uncover recon engines below.

# FOFA — needs BOTH email and key. Free accounts have 0 API quota (web only).
FOFA_EMAIL=
FOFA_KEY=

# Hunter — hunter.qianxin.com
HUNTER_API_KEY=

# Quake — quake.360.net
QUAKE_TOKEN=
